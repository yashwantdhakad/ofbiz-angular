{
  "name": "ofbiz-angular",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "test:ci": "ng test --watch=false --karma-config karma.codex.conf.js --source-map=false",
    "test:ci:all": "npm run test:ci:shard:1 && npm run test:ci:shard:2",
    "test:ci:shard:1": "node ./scripts/run-test-shard.mjs 0 55",
    "test:ci:shard:2": "node ./scripts/run-test-shard.mjs 55",
    "test:coverage": "ng test --watch=false --karma-config karma.codex.conf.js --source-map=false --code-coverage",
    "lint": "eslint \"src/**/*.{ts,html}\"",
    "lint:sonar": "mkdir -p reports && eslint \"src/**/*.{ts,html}\" -f json -o reports/eslint-report.json"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^21.2.18",
    "@angular/cdk": "^21.1.5",
    "@angular/common": "^21.2.18",
    "@angular/compiler": "^21.2.18",
    "@angular/core": "^21.2.18",
    "@angular/flex-layout": "^15.0.0-beta.42",
    "@angular/forms": "^21.2.18",
    "@angular/material": "^21.1.5",
    "@angular/platform-browser": "^21.2.18",
    "@angular/platform-browser-dynamic": "^21.2.18",
    "@angular/router": "^21.2.18",
    "@ngrx/effects": "^21.0.0",
    "@ngrx/store": "^21.0.0",
    "@ngx-translate/core": "^15.0.0",
    "@ngx-translate/http-loader": "^8.0.0",
    "@zxing/ngx-scanner": "^21.0.0",
    "rxjs": "^7.8.1",
    "tslib": "^2.6.2",
    "zone.js": "~0.16.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^21.2.19",
    "@angular-eslint/eslint-plugin": "^21.3.1",
    "@angular-eslint/eslint-plugin-template": "^21.3.1",
    "@angular-eslint/template-parser": "^21.3.1",
    "@angular/cli": "^21.2.19",
    "@angular/compiler-cli": "^21.2.18",
    "@angular/localize": "^21.2.18",
    "@types/jasmine": "~5.1.0",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "eslint": "^9.39.4",
    "eslint-plugin-sonarjs": "^4.1.0",
    "jasmine-core": "~5.1.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "typescript": "~5.9.3"
  },
  "overrides": {
    "uuid": "^11.1.1"
  }
}
